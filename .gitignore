# Terraform
**/.terraform/*
*.tfstate
*.tfstate.*
.terraform.lock.hcl
*.tfvars
*.tfvars.json
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraform.tfstate.lock.info

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files (may contain secrets)
*.tfvars
*.tfvars.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# OS files
.DS_Store
Thumbs.db

# IDE files
.idea/
.vscode/
*.swp
*.swo
*~

# AWS
.aws/
aws-credentials.txt

# Kubernetes
kubeconfig*
*.kubeconfig

# Sensitive outputs (access keys, etc.)
credentials.txt
secrets.yaml
*-secret.yaml
.env
.env.local

# Keep the bootstrap state separate
terraform/bootstrap/.terraform/
terraform/bootstrap/terraform.tfstate*
terraform/bootstrap/.terraform.lock.hcl


.dontpush